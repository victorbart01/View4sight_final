# View4Sight — variables d'environnement
# Copier ce fichier en .env.local et remplir avec les VRAIES valeurs.
# Ne jamais committer .env.local (il est dans .gitignore).

# --- Polar (paiements) ---
# Token généré dans Polar > Settings > Developers (voir POLAR_SETUP.md)
POLAR_ACCESS_TOKEN=polar_pat_xxxxxxxxxxxxxxxx
# "sandbox" en test, "production" en prod
POLAR_SERVER=production

# URL publique du site (sert aux redirections de paiement)
NEXT_PUBLIC_BASE_URL=https://view4sight.com

# --- Email (formulaire de contact / demande de démo, via nodemailer) ---
EMAIL_SERVER_HOST=smtp.exemple.com
EMAIL_SERVER_PORT=465
EMAIL_SERVER_USER=contact@view4sight.com
EMAIL_SERVER_PASSWORD=xxxxxxxxxxxxxxxx
EMAIL_FROM=contact@view4sight.com
